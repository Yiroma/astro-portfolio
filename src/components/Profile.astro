---
import { getCollection } from "astro:content";
import Container from "@components/ui/Container.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import ProfilePillar from "@components/ProfilePillar.astro";

const pillars = (await getCollection("profile")).sort((a, b) => a.data.order - b.data.order);
---

<section id="profil" class="profile-section relative z-10 py-16 md:py-24">
  <Container>
    <div class="mb-12 md:mb-16">
      <Eyebrow class="mb-3">Pourquoi me recruter</Eyebrow>
      <h2>
        Un développeur qui pense<br />avant de coder.
      </h2>
    </div>

    <div class="profile-grid">
      {
        pillars.map((pillar, index) => (
          <ProfilePillar
            eyebrow={pillar.data.eyebrow}
            title={pillar.data.title}
            tags={pillar.data.tags}
            illustration={pillar.data.illustration}
            alternate={index % 2 !== 0}
          >
            {pillar.data.description}
          </ProfilePillar>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .profile-section {
    background: var(--color-base-200);
    box-shadow:
      0 -20px 24px rgba(0, 0, 0, 0.06),
      0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .profile-grid {
    display: flex;
    flex-direction: column;
  }

  .profile-grid > :global(*) {
    padding-block: 2.5rem;
  }

  .profile-grid > :global(*:first-child) {
    padding-top: 0;
  }

  .profile-grid > :global(*:last-child) {
    padding-bottom: 0;
  }

  .profile-grid > :global(* + *) {
    border-top: 1px solid var(--color-base-300);
  }
</style>
