---
type Variant = "primary" | "secondary" | "outline" | "ghost";
type Size = "sm" | "md" | "lg" | "icon";
type Target = "_blank" | "_self" | "_parent" | "_top";

interface Props {
  href?: string;
  variant?: Variant;
  size?: Size;
  target?: Target;
  rel?: string;
  muted?: boolean;
  class?: string;
  "aria-label"?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  download?: boolean | string;
}

const {
  href,
  variant = "primary",
  size = "md",
  muted = false,
  target,
  rel,
  class: className,
  "aria-label": ariaLabel,
  type = "button",
  disabled,
  download,
} = Astro.props;

const rel_ = target === "_blank" ? (rel ?? "noopener noreferrer") : rel;
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={rel_}
      download={download}
      aria-label={ariaLabel}
      class:list={["btn", `btn--${variant}`, `btn--${size}`, { "btn--muted": muted }, className]}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      disabled={disabled}
      aria-label={ariaLabel}
      class:list={["btn", `btn--${variant}`, `btn--${size}`, { "btn--muted": muted }, className]}
    >
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 500;
    border-radius: 0.375rem;
    border: 1px solid transparent;
    white-space: nowrap;
    cursor: pointer;
    transition:
      filter 150ms ease,
      background 150ms ease,
      border-color 150ms ease,
      opacity 150ms ease;
  }

  .btn:disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .btn--sm {
    height: 2rem;
    padding-inline: 0.75rem;
    font-size: 0.8125rem;
  }
  .btn--md {
    height: 2.75rem;
    padding-inline: 1.25rem;
    font-size: 0.875rem;
  }
  .btn--lg {
    height: 3.25rem;
    padding-inline: 1.75rem;
    font-size: 1rem;
  }
  .btn--icon {
    width: 2rem;
    height: 2rem;
    padding: 0;
    flex-shrink: 0;
  }

  .btn--primary {
    background: var(--color-primary);
    color: var(--color-primary-content);
    border-color: var(--color-primary);
  }
  .btn--primary:hover {
    filter: brightness(0.9);
  }

  .btn--secondary {
    background: var(--color-base-200);
    color: var(--color-base-content);
    border-color: var(--color-base-300);
  }
  .btn--secondary:hover {
    background: var(--color-base-300);
  }

  .btn--outline {
    background: transparent;
    color: var(--color-base-content);
    border-color: var(--color-base-300);
  }
  .btn--outline:hover {
    background: var(--color-base-200);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-base-content);
    border-color: transparent;
  }
  .btn--ghost:hover {
    background: var(--color-base-200);
  }

  .btn--muted {
    opacity: 0.6;
  }
  .btn--muted:hover {
    opacity: 1;
    border-color: var(--color-primary);
  }
</style>
