---
interface Props {
  as?: "p" | "span";
  class?: string;
}

const { as: Tag = "p", class: className } = Astro.props;
---

<Tag class:list={["eyebrow", className]}>
  <slot />
</Tag>

<style>
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    line-height: 1.4;
  }
</style>
