---
import BlobBackground from "@components/ui/BlobBackground.astro";
import Container from "@components/ui/Container.astro";
import ContactCTA from "@components/ContactCTA.astro";
import ContactForm from "@components/ContactForm.astro";
---

<section id="contact" class="contact-section relative z-0 overflow-hidden py-16 md:py-24">
  <BlobBackground />

  <Container class="relative z-10">
    <div class="overflow-hidden rounded-2xl border border-primary/20">
      <div class="grid grid-cols-1 lg:grid-cols-5">
        <ContactCTA />
        <ContactForm />
      </div>
    </div>
  </Container>
</section>

<style>
  /* color-mix avec base-100 non exprimable en Tailwind */
  .contact-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base-100));
  }
</style>
