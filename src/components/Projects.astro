---
import { getCollection } from "astro:content";
import BlobBackground from "@components/ui/BlobBackground.astro";
import Container from "@components/ui/Container.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import ProjectsGrid from "@components/react/ProjectsGrid";
import type { Project } from "@components/react/ProjectsGrid";
import Button from "@components/ui/Button.astro";
import GithubIcon from "@components/ui/icons/GithubIcon.astro";

const entries = await getCollection("projects");
const projects: Project[] = entries
  .map((entry) => entry.data as Project)
  .sort((a, b) => a.index - b.index);
---

<section id="realisations" class="projects-section relative z-0 overflow-hidden py-16 md:py-24">
  <BlobBackground />

  <Container class="relative z-10">
    <div class="mb-12">
      <Eyebrow class="mb-3">Ce que j'ai livré</Eyebrow>
      <h2>Des projets réels,<br />du contexte, des résultats.</h2>
    </div>

    <ProjectsGrid projects={projects} client:visible />

    <div class="mt-10">
      <Button href="https://github.com/Yiroma" variant="outline" target="_blank" class="w-full">
        Voir plus de projets sur GitHub
        <GithubIcon aria-hidden="true" />
      </Button>
    </div>
  </Container>
</section>

<style>
  .projects-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base-100));
  }
</style>
