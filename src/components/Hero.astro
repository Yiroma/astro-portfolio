---
import AvailabilityBadge from "@components/ui/AvailabilityBadge.astro";
import BlobBackground from "@components/ui/BlobBackground.astro";
import Button from "@components/ui/Button.astro";
import Container from "@components/ui/Container.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import GradientText from "@components/ui/GradientText.astro";
import { socialLinks } from "@data/nav";
import { ChevronDown, Download } from "@lucide/astro";
import { Image } from "astro:assets";
import profilePhoto from "@assets/romaric-yi.png";
---

<section id="hero" class="hero-section relative z-0 overflow-hidden py-16 md:py-20">
  <BlobBackground />

  <Container class="relative z-10">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
      <div class="hero-text-col flex flex-col items-start justify-center">
        <AvailabilityBadge
          label="Disponible — CDI · Mission · Freelance"
          class="hero-anim-badge mb-6"
        />

        <Eyebrow class="hero-anim-badge mb-4">
          Développeur Full Stack · Orléans & Remote France
        </Eyebrow>

        <h1 class="hero-anim-title mb-6">
          Je conçois des applications<br />
          <GradientText>pensées pour durer.</GradientText>
        </h1>

        <p class="hero-anim-desc mb-4 max-w-lg">
          Développeur Full Stack diplômé <strong class="text-base-content"
            >Concepteur Développeur d'Applications (Bac+4, RNCP 37873)</strong
          >, spécialisé en architectures sécurisées avec <strong class="text-base-content"
            >React, Next.js, Node.js, TypeScript</strong
          > et <strong class="text-base-content">Java/Spring Boot</strong>.
        </p>
        <p class="hero-anim-desc mb-10 max-w-lg">
          <strong class="text-base-content">10 ans de management</strong> avant d'entrer dans le développement
          : je traduis des besoins flous en solutions concrètes, et je communique avec les profils non-tech
          sans les perdre.
        </p>

        <div class="hero-anim-cta mb-6 flex flex-wrap gap-3">
          <Button href="#realisations" variant="primary" size="md">
            <ChevronDown size={16} />
            Voir mes réalisations</Button
          >
          <Button
            href="/CV-Romaric-Yi-Full-Stack-Developer.pdf"
            variant="outline"
            size="md"
            target="_blank"
          >
            <Download size={16} />
            Télécharger mon CV
          </Button>
        </div>

        <div class="hero-anim-cta flex items-center gap-3">
          {
            socialLinks.map(({ label, href, icon: Icon }) => (
              <Button
                href={href}
                variant="outline"
                size="icon"
                muted
                target={href.startsWith("mailto:") ? undefined : "_blank"}
                aria-label={label}
              >
                <Icon class="size-4" />
              </Button>
            ))
          }
        </div>
      </div>

      <div class="hero-photo-spacer hidden md:block" aria-hidden="true"></div>
    </div>
  </Container>

  <div class="hero-anim-image hero-photo-col" aria-hidden="true">
    <Image
      src={profilePhoto}
      alt=""
      class="hero-photo"
      width={640}
      height={853}
      format="webp"
      quality={85}
    />
  </div>
</section>

<style>
  .hero-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base-100));
  }

  .hero-photo-col {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 50%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
  }

  .hero-photo {
    display: block;
    width: auto;
    height: 110%;
    max-width: 100%;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(-16px 0 40px color-mix(in oklch, var(--color-primary) 25%, transparent));
  }

  @media (max-width: 767px) {
    .hero-photo-col {
      width: 80%;
      right: -10%;
    }

    .hero-photo {
      opacity: 0.45;
    }

    .hero-text-col p,
    .hero-text-col :global(.eyebrow) {
      text-shadow:
        0 2px 8px var(--color-base-100),
        0 4px 20px var(--color-base-100);
    }
  }

  /* Entrées animées */
  @keyframes hero-scale-in {
    from {
      opacity: 0;
      transform: scale(0.85);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes hero-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes hero-photo-in {
    from {
      opacity: 0;
      transform: translateY(60px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-anim-badge {
    animation: hero-scale-in 0.35s ease-out both;
  }
  .hero-anim-title {
    animation: hero-fade-up 0.5s ease-out 0.08s both;
  }
  .hero-anim-desc {
    animation: hero-fade-up 0.5s ease-out 0.16s both;
  }
  .hero-anim-cta {
    animation: hero-fade-up 0.5s ease-out 0.24s both;
  }
  .hero-anim-image {
    animation: hero-photo-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim-badge,
    .hero-anim-title,
    .hero-anim-desc,
    .hero-anim-cta,
    .hero-anim-image {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
