---
import AvailabilityBadge from "@components/ui/AvailabilityBadge.astro";
import BlobBackground from "@components/ui/BlobBackground.astro";
import Button from "@components/ui/Button.astro";
import Container from "@components/ui/Container.astro";
import Eyebrow from "@components/ui/Eyebrow.astro";
import GradientText from "@components/ui/GradientText.astro";
import { socialLinks } from "@data/nav";
import { ChevronDown, Download } from "@lucide/astro";
import { Image } from "astro:assets";
import profilePhoto from "@assets/romaric-yi.png";
---

<section id="hero" class="hero-section relative z-0 overflow-hidden py-20 md:py-32">
  <BlobBackground />

  <Container class="relative z-10">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
      <div class="flex flex-col items-start">
        <AvailabilityBadge
          label="Disponible — CDI · Mission · Freelance"
          class="hero-anim-badge mb-6"
        />

        <Eyebrow class="hero-anim-badge mb-4">
          Développeur Full Stack · Orléans & Remote France
        </Eyebrow>

        <h1 class="hero-anim-title mb-6">
          Je conçois des applications<br />
          <GradientText>pensées pour durer.</GradientText>
        </h1>

        <p class="hero-anim-desc mb-4 max-w-lg">
          Développeur Full Stack diplômé <strong class="text-base-content"
            >Concepteur Développeur d'Applications (Bac+4, RNCP 37873)</strong
          >, spécialisé en architectures sécurisées avec <strong class="text-base-content"
            >React, Next.js, Node.js, TypeScript</strong
          > et <strong class="text-base-content">Java/Spring Boot</strong>.
        </p>
        <p class="hero-anim-desc mb-10 max-w-lg">
          <strong class="text-base-content">10 ans de management</strong> avant d'entrer dans le développement
          : je traduis des besoins flous en solutions concrètes, et je communique avec les profils non-tech
          sans les perdre.
        </p>

        <div class="hero-anim-cta mb-6 flex flex-wrap gap-3">
          <Button href="#realisations" variant="primary" size="md">
            <ChevronDown size={16} />
            Voir mes réalisations</Button
          >
          <Button
            href="/CV-Romaric-Yi-Full-Stack-Developer.pdf"
            variant="outline"
            size="md"
            target="_blank"
          >
            <Download size={16} />
            Télécharger mon CV
          </Button>
        </div>

        <div class="hero-anim-cta flex items-center gap-3">
          {
            socialLinks.map(({ label, href, icon: Icon }) => (
              <Button
                href={href}
                variant="outline"
                size="icon"
                muted
                target={href.startsWith("mailto:") ? undefined : "_blank"}
                aria-label={label}
              >
                <Icon class="size-4" />
              </Button>
            ))
          }
        </div>
      </div>

      <div class="hero-anim-image flex items-center justify-center">
        <div class="hero-photo-wrapper">
          <Image
            src={profilePhoto}
            alt="Romaric Yi — Développeur Full Stack"
            class="h-full w-full object-cover"
            style="object-position: center 85%"
            width={400}
            height={533}
            format="webp"
            quality={85}
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-section {
    background: color-mix(in srgb, var(--color-primary) 4%, var(--color-base-100));
  }

  .hero-photo-wrapper {
    position: relative;
    width: min(380px, 80vw);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    background: radial-gradient(
      circle at 60% 40%,
      color-mix(in oklch, var(--color-primary) 90%, oklch(0.7 0.15 200)),
      color-mix(in oklch, var(--color-primary) 60%, oklch(0.2 0.05 280)) 100%
    );
    box-shadow: 0 0 64px color-mix(in oklch, var(--color-primary) 45%, transparent);
  }

  @media (max-width: 767px) {
    .hero-photo-wrapper {
      width: min(260px, 70vw);
    }
  }

  /* Entrées animées */
  @keyframes hero-scale-in {
    from {
      opacity: 0;
      transform: scale(0.85);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes hero-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .hero-anim-badge {
    animation: hero-scale-in 0.35s ease-out both;
  }
  .hero-anim-title {
    animation: hero-fade-up 0.5s ease-out 0.08s both;
  }
  .hero-anim-desc {
    animation: hero-fade-up 0.5s ease-out 0.16s both;
  }
  .hero-anim-cta {
    animation: hero-fade-up 0.5s ease-out 0.24s both;
  }
  .hero-anim-image {
    animation: hero-fade-in 0.6s ease-out 0.4s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim-badge,
    .hero-anim-title,
    .hero-anim-desc,
    .hero-anim-cta,
    .hero-anim-image {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
