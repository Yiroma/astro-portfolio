---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "@components/react/CookieBanner";

const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;

type Props = {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
};

const {
  title,
  description,
  image = "/og.png",
  canonical = "https://yiromaric.fr/",
} = Astro.props as Props;

const siteUrl = "https://yiromaric.fr";
const fullImageUrl = image.startsWith("http") ? image : `${siteUrl}${image}`;

const dateModified = "2026-05-16";

const jsonLdWebSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Romaric Yi — Portfolio",
  url: siteUrl,
  description:
    "Portfolio de Romaric Yi, Développeur Full Stack JS/TS basé à Châteauneuf-sur-Loire.",
  author: { "@type": "Person", name: "Romaric Yi" },
  dateModified,
};

const jsonLdFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Qui est Romaric Yi ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Romaric Yi est un développeur Full Stack diplômé Concepteur Développeur d'Applications (Bac+4, RNCP 37873), spécialisé en React, TypeScript, Next.js, Node.js et Java/Spring Boot. Basé à Châteauneuf-sur-Loire, il est disponible en CDI, CDD, mission courte, mission longue ou freelance, en présentiel sur Orléans et sa région ou distanciel dans toute la France.",
      },
    },
    {
      "@type": "Question",
      name: "Quelles sont les compétences de Romaric Yi ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Front-end : React, Next.js, TypeScript, Tailwind CSS, accessibilité RGAA/WCAG 2.1. Back-end : Node.js, Express, Java, Spring Boot, GraphQL. DevOps : Docker, CI/CD. Bases de données : PostgreSQL, MySQL, SQLite, Redis.",
      },
    },
    {
      "@type": "Question",
      name: "Romaric Yi est-il disponible en freelance ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Oui, Romaric Yi est disponible pour des missions freelance, des CDD, des CDI, des missions courtes et des missions longues en remote sur toute la France.",
      },
    },
  ],
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Romaric Yi",
  jobTitle: "Concepteur Développeur d'Applications Full Stack",
  description:
    "Développeur Full Stack Bac+4 CDA (RNCP 37873) basé à Châteauneuf-sur-Loire. React, TypeScript, Next.js, Node.js, Java/Spring Boot, GraphQL, PostgreSQL, Docker. 10 ans de management en reconversion réussie.",
  url: siteUrl,
  image: `${siteUrl}/og.png`,
  email: "yiromaric@gmail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Châteauneuf-sur-Loire",
    addressRegion: "Centre-Val de Loire",
    postalCode: "45110",
    addressCountry: "FR",
  },
  sameAs: ["https://github.com/Yiroma", "https://www.linkedin.com/in/yiromaric/"],
  alumniOf: [
    {
      "@type": "EducationalOrganization",
      name: "Wild Code School",
      url: "https://www.wildcodeschool.com",
    },
  ],
  hasCredential: [
    {
      "@type": "EducationalOccupationalCredential",
      name: "Concepteur Développeur d'Applications",
      credentialCategory: "Titre professionnel RNCP 37873 niveau 6 (Bac+4)",
      recognizedBy: { "@type": "Organization", name: "France Compétences" },
    },
    {
      "@type": "EducationalOccupationalCredential",
      name: "Développeur Web et Web Mobile",
      credentialCategory: "Titre professionnel RNCP 31114 niveau 5 (Bac+2)",
      recognizedBy: { "@type": "Organization", name: "France Compétences" },
    },
  ],
  knowsLanguage: ["fr-FR", "en"],
  knowsAbout: [
    "React",
    "Next.js",
    "Astro",
    "TypeScript",
    "JavaScript",
    "Tailwind CSS",
    "Sass",
    "Node.js",
    "Express",
    "GraphQL",
    "Apollo Server",
    "TypeORM",
    "Java",
    "Spring Boot",
    "API REST",
    "PostgreSQL",
    "MySQL",
    "SQLite",
    "MongoDB",
    "Redis",
    "Docker",
    "Nginx",
    "CI/CD",
    "GitHub Actions",
    "Clean Architecture",
    "Microservices",
    "UML",
    "Merise",
    "Git",
    "Vitest",
    "Jest",
    "Playwright",
    "RGAA",
    "WCAG 2.1",
    "Accessibilité web",
    "SEO technique",
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="favicon.ico" type="image/x-icon" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <!-- SEO Meta Tags -->
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content="Romaric Yi" />
    <link rel="canonical" href={canonical} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Romaric Yi — Portfolio" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:image:alt" content="Portfolio de Romaric Yi, Développeur Full Stack" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    <meta name="twitter:image:alt" content="Portfolio de Romaric Yi, Développeur Full Stack" />
    <!-- Title -->
    <title>{title}</title>
    <!-- Structured Data JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLdWebSite)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLdFaq)} />
    <!-- Google Consent Mode v2 — désactivé par défaut (RGPD) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      gtag("consent", "default", {
        analytics_storage: "denied",
        ad_storage: "denied",
        wait_for_update: 500,
      });
    </script>
  </head>
  <body class="flex flex-col bg-base-200">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:rounded focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-content focus:outline-none"
    >
      Aller au contenu principal
    </a>
    <Header />
    <main id="main-content" class="flex flex-1 flex-col">
      <slot />
    </main>
    <Footer />
    {GA_ID && <CookieBanner measurementId={GA_ID} client:load />}
  </body>
</html>
